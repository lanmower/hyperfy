{
  "enabled": false,
  "provider": "coolify",
  "metrics": {
    "cpu": {
      "threshold": 75,
      "action": "scale_up",
      "duration": 300,
      "step": 1
    },
    "memory": {
      "threshold": 80,
      "action": "scale_up",
      "duration": 300,
      "step": 1
    },
    "connections": {
      "threshold": 500,
      "action": "scale_up",
      "duration": 60,
      "step": 1
    }
  },
  "scaling": {
    "minInstances": 1,
    "maxInstances": 10,
    "targetInstanceCount": 1,
    "cooldownPeriod": 300,
    "scaleUpStep": 1,
    "scaleDownStep": -1,
    "scaleDownThreshold": 30,
    "scaleDownDuration": 600
  },
  "healthCheck": {
    "endpoint": "/health",
    "interval": 30,
    "timeout": 5,
    "unhealthyThreshold": 3,
    "healthyThreshold": 2
  }
}
